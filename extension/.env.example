VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: required only for Google Contacts sync (#6)
# Get from Google Cloud Console → OAuth 2.0 Client ID (Chrome Extension type)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional: required for AI field suggestions
# Get from 阿里云百炼 (https://bailian.console.aliyun.com/) → API Key
VITE_DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required for vehicle media upload (images / videos / spec sheets)
# Get from cloudinary.com Dashboard
# Create an unsigned upload preset at Settings → Upload → Add upload preset (Signing Mode: Unsigned)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name
